# Supabase 프로젝트 → Project Settings → API 에서 값 복사
# 대시보드의 "Publishable key"(신규) 또는 레거시 "anon key" 값을 ANON_KEY 에 입력한다.
# 이 키는 RLS 로 보호되므로 브라우저 노출이 안전하다.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-OR-ANON-KEY

# 주의: secret / service-role 키는 이 MVP 에 필요 없으며,
#       절대 NEXT_PUBLIC_ 접두사로 노출하지 말 것.

# YouTube Data API v3 키 (서버 전용 — NEXT_PUBLIC_ 접두사 금지).
# Google Cloud Console → APIs & Services → "YouTube Data API v3" 사용 설정 →
# Credentials → Create credentials → "API key" 발급(OAuth 클라이언트 ID 아님).
# 미설정 시 곡 등록의 YouTube 검색만 비활성화되고 수동 입력은 정상 동작.
YOUTUBE_API_KEY=YOUR-YOUTUBE-DATA-API-KEY
